{
  "manifest_version": 3,
  "name": "Fusion Etsy Puller",
  "version": "1.1.0",
  "description": "Pull Etsy orders into FUSION OS (read-only, safe) + status overlay + tracking autofill",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.etsy.com/*",
    "https://os.fusiondn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.etsy.com/your/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "icon32.png"
      ],
      "matches": [
        "https://www.etsy.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}